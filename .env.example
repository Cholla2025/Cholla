# Cholla Check-In — Supabase connection (client-side, safe to expose)
#
# These two values are PUBLIC by design and ship in the browser bundle.
# The anon key is protected by Row Level Security policies on the database.
# Copy this file to `.env.local` and fill in your project's values, OR set
# them in Vercel → Project → Settings → Environment Variables.
#
# NEVER put the service_role key here or anywhere in this repo.
# If the demo runs without these set, it falls back to built-in sample data.

VITE_SUPABASE_URL=https://dnipgngvsdktdyqthurq.supabase.co
VITE_SUPABASE_ANON_KEY=
